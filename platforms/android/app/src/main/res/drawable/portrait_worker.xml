<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer gold frame -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFD700"
                android:centerColor="#B8860B"
                android:endColor="#8B6914"/>
        </shape>
    </item>

    <!-- Inner dark background -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="#2D1F15"/>
        </shape>
    </item>

    <!-- Character portrait image -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <bitmap
            android:src="@drawable/img_portrait_worker"
            android:gravity="fill"/>
    </item>

    <!-- Inner highlight rim -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#FFD70050"/>
        </shape>
    </item>
</layer-list>
