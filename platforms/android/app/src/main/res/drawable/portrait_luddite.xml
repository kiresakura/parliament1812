<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer gold frame -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFD700"
                android:centerColor="#B8860B"
                android:endColor="#8B6914"/>
            <size android:width="200dp" android:height="240dp"/>
        </shape>
    </item>

    <!-- Inner dark background -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:startColor="#3D2020"
                android:endColor="#251515"/>
        </shape>
    </item>

    <!-- Character accent glow (luddite crimson red) -->
    <item android:left="16dp" android:top="16dp" android:right="16dp" android:bottom="16dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="100dp"
                android:startColor="#8B0000"
                android:centerColor="#5C0000"
                android:endColor="#3D0000"/>
        </shape>
    </item>

    <!-- Inner highlight rim -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#FFD70050"/>
        </shape>
    </item>
</layer-list>
