<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#00000080"/>
        </shape>
    </item>

    <!-- Main gold frame -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="6dp">
                <gradient
                    android:type="linear"
                    android:angle="135"
                    android:startColor="#FFD700"
                    android:centerColor="#B8860B"
                    android:endColor="#8B6914"/>
            </stroke>
        </shape>
    </item>

    <!-- Inner highlight -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#FFD70060"/>
        </shape>
    </item>

    <!-- Inner shadow -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#5D4E3780"/>
        </shape>
    </item>
</layer-list>
