<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ========== Distribution Method ========== -->
	<!-- Options: app-store, ad-hoc, enterprise, development -->
	<key>method</key>
	<string>development</string>

	<!-- ========== Team Configuration ========== -->
	<!-- Replace with your Apple Developer Team ID -->
	<key>teamID</key>
	<string>YOUR_TEAM_ID</string>

	<!-- ========== Signing Configuration ========== -->
	<key>signingStyle</key>
	<string>automatic</string>

	<key>signingCertificate</key>
	<string>Apple Development</string>

	<!-- ========== Provisioning Profiles ========== -->
	<!-- Uncomment and configure for manual signing -->
	<!--
	<key>provisioningProfiles</key>
	<dict>
		<key>com.parliament1812.app</key>
		<string>Parliament 1812 Development</string>
	</dict>
	-->

	<!-- ========== Build Options ========== -->
	<key>compileBitcode</key>
	<false/>

	<key>stripSwiftSymbols</key>
	<true/>

	<key>uploadBitcode</key>
	<false/>

	<key>uploadSymbols</key>
	<true/>

	<!-- ========== App Thinning ========== -->
	<key>thinning</key>
	<string>&lt;none&gt;</string>

	<!-- ========== On-Demand Resources ========== -->
	<!-- Enable if using on-demand resources -->
	<!--
	<key>embedOnDemandResourcesAssetPacksInBundle</key>
	<true/>
	-->

	<!-- ========== iCloud Configuration ========== -->
	<!-- Enable if using iCloud -->
	<!--
	<key>iCloudContainerEnvironment</key>
	<string>Development</string>
	-->

	<!-- ========== Manifest for OTA Distribution ========== -->
	<!-- Configure for ad-hoc distribution -->
	<!--
	<key>manifest</key>
	<dict>
		<key>appURL</key>
		<string>https://your-server.com/path/to/app.ipa</string>
		<key>displayImageURL</key>
		<string>https://your-server.com/path/to/display-image.png</string>
		<key>fullSizeImageURL</key>
		<string>https://your-server.com/path/to/full-size-image.png</string>
	</dict>
	-->
</dict>
</plist>
