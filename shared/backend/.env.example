# Parliament 1812 Backend 環境變數範例
# 複製此檔案為 .env 並填入實際值

# 應用程式設定
APP_NAME=Parliament 1812
APP_VERSION=1.0.0
DEBUG=true

# 資料庫設定 (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/parliament1812

# Redis 設定
REDIS_URL=redis://localhost:6379/0

# 安全性設定
SECRET_KEY=your-super-secret-key-change-in-production

# CORS 設定（多個來源用逗號分隔，或使用 * 允許所有）
CORS_ORIGINS=*

# WebSocket 設定
WS_HEARTBEAT_INTERVAL=30

# 遊戲設定
MAX_PLAYERS_PER_ROOM=20
ROOM_CODE_LENGTH=6
