# 1812 國會風雲 - 後端伺服器環境變數

# ============================================================
# 本地開發環境設定
# ============================================================

# 伺服器設定
HOST=0.0.0.0
PORT=8080

# 資料庫設定
DATABASE_URL=postgres://user:password@localhost:5432/parliament1812
DATABASE_MAX_CONNECTIONS=10

# Redis 設定
REDIS_URL=redis://localhost:6379

# JWT 設定
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# 日誌設定
RUST_LOG=info

# 環境設定 (development | production)
RUST_ENV=development

# ============================================================
# 生產環境設定（Fly.io）
# ============================================================
#
# 在 Fly.io 上使用 fly secrets 設定敏感資訊：
#
#   fly secrets set DATABASE_URL="postgres://user:pass@host:5432/db"
#   fly secrets set REDIS_URL="redis://default:pass@host:6379"
#   fly secrets set JWT_SECRET="your-production-secret-key"
#
# 非敏感環境變數可在 fly.toml 的 [env] 區塊設定：
#
#   [env]
#     RUST_LOG = "info"
#     RUST_BACKTRACE = "1"
#     RUST_ENV = "production"
#
# ============================================================
# Fly.io Postgres 資料庫
# ============================================================
#
# 建立 Postgres 資料庫：
#   fly postgres create --name parliament1812-db --region nrt
#
# 連接到應用程式：
#   fly postgres attach parliament1812-db
#
# 這會自動設定 DATABASE_URL secret
#
# ============================================================
# Fly.io Redis (Upstash)
# ============================================================
#
# 建立 Upstash Redis：
#   fly redis create --name parliament1812-redis --region nrt
#
# 這會自動設定 REDIS_URL secret
#
# 或使用外部 Redis 服務（如 Upstash、Redis Cloud）：
#   fly secrets set REDIS_URL="redis://default:password@host:6379"
#
# ============================================================
# 部署指令
# ============================================================
#
# 首次部署：
#   cd server
#   fly launch --no-deploy
#   fly postgres create --name parliament1812-db
#   fly postgres attach parliament1812-db
#   fly secrets set JWT_SECRET="$(openssl rand -hex 32)"
#   fly deploy
#
# 後續部署：
#   fly deploy
#
# 查看日誌：
#   fly logs
#
# 連接到運行中的實例：
#   fly ssh console
#
# ============================================================
